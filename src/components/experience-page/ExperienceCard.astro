---
/**
 * ExperienceCard.astro
 * A small reusable card component for project/publication/research items.
 * Props:
 *  - type: 'project' | 'publication' | 'research'
 *  - item: any (shape depends on type)
 *  - index?: number (for stagger)
 */
interface Props {
  type: "project" | "publication" | "research";
  item: any;
  index?: number;
}

const { type, item, index = 0 } = Astro.props as Props;
---

<article class="card reveal opacity-0 translate-y-2 transition-opacity transition-transform duration-300 ease-out border border-base-300 bg-base-200/50 p-5 rounded-lg">
  <div class="flex flex-wrap items-baseline justify-between gap-2">
    <h3 class="text-lg font-semibold tracking-tight text-base-content">{item.title}</h3>
    {type === 'project' && <p class="text-sm text-base-content/65">{item.period}</p>}
    {type === 'publication' && <p class="text-sm text-base-content/65">{item.year}</p>}
  </div>

  <p class="mt-2.5 leading-7 text-base-content/85">{item.summary ?? item.venue ?? ''}</p>

  {type === 'project' && item.tech && (
    <p class="mt-3 text-sm text-base-content/65">
      <span class="font-semibold uppercase tracking-wide text-base-content/85">Tech</span>: {item.tech.join(", ")}
    </p>
  )}

  {type === 'research' && item.keywords && (
    <ul class="mt-4 flex flex-wrap gap-2">
      {item.keywords.map((keyword: string) => (
        <li class="border border-base-300 bg-base-100/60 px-2 py-1 text-xs tracking-wide text-base-content/65">{keyword}</li>
      ))}
    </ul>
  )}

  {item.link && (
    <a
      href={item.link}
      target="_blank"
      rel="noreferrer noopener"
      class="inline-flex mt-4 h-9 items-center border border-base-300 px-3 text-sm text-base-content transition hover:border-base-content hover:text-base-content focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-base-content/40"
    >
      View
    </a>
  )}
</article>
