---
import type { ActionLinks, HeroProfile } from "../../data/experience";

interface Props {
  profile: HeroProfile;
  links: ActionLinks;
}

const { profile, links } = Astro.props as Props;
// use a non-typed access to avoid stale type errors in the Astro compiler
const avatarSrc = (profile as any).avatar ?? "/avatars/default.png";
---

<header
  id="hero"
  class="border-b border-base-300 pb-8"
>
  <div class="grid grid-cols-1 lg:grid-cols-[160px_1fr] gap-6 items-center py-6">
    <div class="flex items-center justify-center">
      <div class="w-36 h-36 lg:w-44 lg:h-44 rounded-lg overflow-hidden border border-base-300 bg-base-100 shadow-sm">
        <img src={avatarSrc} alt={`${profile.name} avatar`} class="w-full h-full object-cover" />
      </div>
    </div>

    <div class="flex flex-col gap-5">
      <div>
        <h1 class="text-4xl font-semibold tracking-tight text-base-content sm:text-5xl">{profile.name}</h1>
        <p class="mt-2 text-sm font-medium uppercase tracking-[0.16em] text-base-content/65 sm:text-base">
          {profile.line2} | {profile.line3}
        </p>
      </div>

      <div class="max-w-3xl border border-base-300 bg-base-200/50 p-5">
        <h2 class="text-xs font-semibold uppercase tracking-[0.14em] text-base-content/85">
          {profile.researchTitle}
        </h2>
        <ul class="mt-3 list-disc pl-5 text-base-content/85">
          {profile.researchBullets.map((item) => <li class="leading-7">{item}</li>)}
        </ul>
        <p class="mt-3 leading-7 text-base-content/85">{profile.closing}</p>
      </div>

      <div class="flex flex-wrap gap-2.5">
        <a
          href={links.githubUrl}
          target="_blank"
          rel="noreferrer noopener"
          class="inline-flex h-9 items-center border border-base-300 px-3 text-sm text-base-content transition hover:border-base-content hover:text-base-content focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-base-content/40"
        >
          GitHub
        </a>
        <a
          href={links.cvUrl}
          download="mr-woo-cv.md"
          class="inline-flex h-9 items-center border border-base-300 px-3 text-sm text-base-content transition hover:border-base-content hover:text-base-content focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-base-content/40"
        >
          Download CV
        </a>
        <a
          href={links.email}
          class="inline-flex h-9 items-center border border-base-300 px-3 text-sm text-base-content transition hover:border-base-content hover:text-base-content focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-base-content/40"
        >
          Email
        </a>
      </div>
    </div>
  </div>
</header>
