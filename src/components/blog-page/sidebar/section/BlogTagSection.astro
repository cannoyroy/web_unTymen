---
// BlogTagSection.astro - Blog tag summary for sidebar
interface Props {
  tags?: string[];
}

const { tags = [] } = Astro.props;
const INITIAL_TAG_COUNT = 12;
const hasMoreTags = tags.length > INITIAL_TAG_COUNT;
const visibleTags = tags.slice(0, INITIAL_TAG_COUNT);
const hiddenTags = hasMoreTags ? tags.slice(INITIAL_TAG_COUNT) : [];
---

<div class="tag-section p-4">
  <div class="mb-3">
    <input
      id="blog-search-input"
      type="search"
      placeholder="搜索文章..."
      class="w-full px-3 py-2 text-sm rounded-lg bg-base-200 border border-base-300 text-base-content placeholder:text-base-content/40 focus:outline-none focus:ring-2 focus:ring-[var(--app-accent)]/30 focus:border-[var(--app-accent)] transition-all"
    />
  </div>

  <div class="flex items-center justify-between px-2 mb-2">
    <h3 class="text-xs font-bold text-base-content/40 uppercase tracking-wider">
      All Tags
    </h3>
    <button
      id="tag-clear-filter"
      class="p-1 hover:bg-base-200 rounded text-base-content/40 transition-colors"
      title="清除筛选"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"
        />
      </svg>
    </button>
  </div>

  <div class="flex flex-wrap gap-1.5 px-2" id="tag-list-container">
    {visibleTags.map((tag) => (
      <button
        class="tag-nav-btn tag-item text-xs px-2 py-1 rounded-full bg-base-200/50 text-base-content/70 hover:bg-[var(--app-accent-soft)] hover:text-[var(--app-accent)] transition-all duration-200"
        data-tag={tag}
        data-tag-group={tag}
      >
        {tag}
      </button>
    ))}

    {hiddenTags.map((tag) => (
      <button
        class="tag-nav-btn tag-item text-xs px-2 py-1 rounded-full bg-base-200/50 text-base-content/70 hover:bg-[var(--app-accent-soft)] hover:text-[var(--app-accent)] transition-all duration-200 hidden"
        data-tag={tag}
        data-tag-group={tag}
        data-tag-hidden
      >
        {tag}
      </button>
    ))}
  </div>

  {hasMoreTags && (
    <button
      id="tag-toggle-expand"
      class="mt-2 px-2 text-xs text-[var(--app-accent)] hover:text-[var(--app-accent-hover)] transition-colors flex items-center gap-1"
      type="button"
    >
      <span>展开全部 ({tags.length})</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" data-expand-icon>
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </button>
  )}

  {tags.length === 0 && (
    <p class="px-2 py-1 text-xs text-base-content/45">
      暂无标签
    </p>
  )}
</div>

<script>
  (() => {
    const toggleBtn = document.getElementById('tag-toggle-expand');
    if (!toggleBtn) return;

    let expanded = false;
    const icon = toggleBtn.querySelector('[data-expand-icon]');
    const label = toggleBtn.querySelector('span');
    const hiddenTags = document.querySelectorAll('[data-tag-hidden]');

    toggleBtn.addEventListener('click', () => {
      expanded = !expanded;
      hiddenTags.forEach((tag) => tag.classList.toggle('hidden', !expanded));
      if (icon) icon.style.transform = expanded ? 'rotate(180deg)' : 'rotate(0deg)';
      if (label) label.textContent = expanded ? '收起' : `展开全部 (${hiddenTags.length + document.querySelectorAll('#tag-list-container > button:not([data-tag-hidden])').length})`;
    });
  })();
</script>
