---
import GitHubIcon from "./icons/contact/GitHubIcon.astro";
import EmailIcon from "./icons/contact/EmailIcon.astro";
import RSSIcon from "./icons/contact/RSSIcon.astro";

type SocialLink = {
  href: string;
  label: string;
  icon: 'github' | 'email' | 'rss';
};

const {
  links = [
    { href: 'https://github.com/cannoyroy', label: 'GitHub', icon: 'github' },
    { href: 'mailto:untymen@163.com', label: 'Email', icon: 'email' },
    { href: '/rss.xml', label: 'RSS', icon: 'rss' },
  ],
} = Astro.props as { links?: SocialLink[] };

const iconMap = {
  github: GitHubIcon,
  email: EmailIcon,
  rss: RSSIcon,
};
---
<div class="grid grid-flow-col gap-4">
  {links.map((item) => {
    const Icon = iconMap[item.icon];
    const isExternal = !item.href.startsWith('mailto:');
    return (
      <a
        href={item.href}
        aria-label={item.label}
        {...(isExternal ? { target: '_blank', rel: 'noreferrer noopener' } : {})}
      >
        <Icon />
      </a>
    );
  })}
</div>
