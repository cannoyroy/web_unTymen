---
import Social from './Social.astro';

type FooterLink = { label: string; href: string };
type SocialLink = { href: string; label: string; icon: 'github' | 'email' | 'rss' };

const {
  projectLink = { label: 'About Me', href: '/about/' },
  socialLinks,
} = Astro.props as {
  projectLink?: FooterLink;
  socialLinks?: SocialLink[];
};
---

<footer class="w-full bg-[var(--app-bg)] border-t border-base-300 mt-16">
  <div class="timeline-container mx-auto w-full max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="text-center space-y-8">
      <!-- Name with dot indicator -->
      <div class="flex items-center justify-center gap-3">
        <span class="h-2 w-2 rounded-full bg-[var(--app-accent)] shadow-[0_0_8px_var(--app-focus)]"></span>
        <h2 class="vcr-font text-2xl font-bold">Reid</h2>
        <span class="h-2 w-2 rounded-full bg-[var(--app-accent)] shadow-[0_0_8px_var(--app-focus)]"></span>
      </div>
      
      <!-- Tagline -->
      <p class="text-sm text-base-content/60 animate-fade-in-up">
        Engineer, Entrepreneur and Student
      </p>

      <!-- Project and Site buttons -->
      <div class="flex flex-wrap justify-center gap-4">
        <a
          class="inline-flex items-center gap-2 px-6 py-2 rounded-full border border-[var(--app-accent)] text-sm text-[var(--app-accent)] hover:bg-[var(--app-accent)] hover:text-[var(--app-accent-contrast)] transition-all duration-300 shadow-[inset_0_0_20px_var(--app-accent-soft)]"
          href={projectLink.href}
        >
          <span class="h-1.5 w-1.5 rounded-full bg-[var(--app-accent)]"></span>
          {projectLink.label}
        </a>
        <a
          class="inline-flex items-center gap-2 px-6 py-2 rounded-full border border-[var(--app-wiki)] text-sm text-[var(--app-wiki)] hover:bg-[var(--app-wiki)] hover:text-[var(--app-wiki-contrast)] transition-all duration-300 shadow-[inset_0_0_20px_var(--app-wiki-soft)]"
          href="https://wiki.untymen.com/"
          target="_blank"
          rel="noreferrer noopener"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-[var(--app-wiki)]"></span>
          My Wiki
        </a>
        <a
          class="inline-flex items-center gap-2 px-6 py-2 rounded-full border border-base-300 text-sm text-base-content/70 hover:border-[var(--app-accent)] hover:text-[var(--app-accent)] transition-all duration-300"
          href="/site"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-base-300"></span>
          This Site
        </a>
      </div>

      <!-- Social links -->
      <div class="flex justify-center">
        <Social links={socialLinks} />
      </div>

      <!-- Copyright -->
      <div class="pt-6 border-t border-base-300">
        <p class="text-xs text-base-content/50 vcr-font">
          © {new Date().getFullYear()} Reid
        </p>
      </div>
    </div>
  </div>

  <style>
    @keyframes fade-in-up {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    .animate-fade-in-up {
      animation: fade-in-up 0.8s ease-out forwards;
    }
  </style>
</footer>
