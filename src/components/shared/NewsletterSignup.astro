---
interface Props {
  source?: string;
  title?: string;
  description?: string;
}

const {
  source = "site",
  title = "Subscribe via Email",
  description = "Get new posts delivered to your inbox. No spam, unsubscribe anytime.",
} = Astro.props as Props;

const buttondownUsername = import.meta.env.PUBLIC_BUTTONDOWN_USERNAME;
const hasProviderConfig = Boolean(buttondownUsername);
const formAction = hasProviderConfig
  ? `https://buttondown.com/api/emails/embed-subscribe/${buttondownUsername}`
  : "";
---

<section class="rounded-2xl border border-base-300 bg-base-100 p-6 md:p-8">
  <h2 class="text-xl font-bold text-base-content">{title}</h2>
  <p class="mt-2 text-sm text-base-content/70">{description}</p>

  {hasProviderConfig ? (
    <form class="mt-5 flex flex-col gap-3 sm:flex-row" action={formAction} method="post" target="popupwindow" onsubmit="window.open('https://buttondown.com', 'popupwindow')">
      <label class="sr-only" for={`newsletter-email-${source}`}>Email address</label>
      <input
        id={`newsletter-email-${source}`}
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder="you@example.com"
        class="input input-bordered w-full"
      />
      <input type="hidden" name="tag" value={source} />
      <button type="submit" class="btn btn-primary whitespace-nowrap">Subscribe</button>
    </form>
  ) : (
    <p class="mt-5 text-sm text-warning">
      Subscription is temporarily unavailable. Missing `PUBLIC_BUTTONDOWN_USERNAME`.
    </p>
  )}

  <p class="mt-3 text-xs text-base-content/55">
    By subscribing, you agree to receive email updates from this blog.
  </p>
</section>
